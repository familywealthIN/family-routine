{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "storybook-static/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "cap:add": {
      "cache": false
    },
    "cap:sync": {
      "dependsOn": ["build"],
      "cache": false
    },
    "cap:build": {
      "dependsOn": ["cap:sync"],
      "cache": false
    },
    "android:build": {
      "dependsOn": ["cap:build"],
      "cache": false
    },
    "android:release": {
      "dependsOn": ["android:build"],
      "cache": false
    },
    "android:internal": {
      "dependsOn": ["android:build"],
      "cache": false
    },
    "fastlane:android": {
      "dependsOn": ["android:build"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "storybook": {
      "cache": false,
      "persistent": true
    }
  }
}
