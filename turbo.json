{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "storybook-static/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^build"
            ]
        },
        "test": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "coverage/**"
            ]
        },
        "storybook": {
            "cache": false,
            "persistent": true
        },
         "ios:add": {},
    "ios:sync": {},
    "ios:open": {},

    "android:add": {},
    "android:sync": {},
    "android:open": {}
    }
}