{
  "name": "routine-notes",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "cross-env": "^7.0.3"
  },
  "resolutions": {
    "node-libs-browser/readable-stream": "^2.3.8",
    "memory-fs/readable-stream": "^2.3.8",
    "concat-stream/readable-stream": "^2.3.8"
  },
  "overrides": {
    "node-libs-browser": {
      "readable-stream": "^2.3.8"
    },
    "memory-fs": {
      "readable-stream": "^2.3.8"
    },
    "concat-stream": {
      "readable-stream": "^2.3.8"
    }
  },
  "prettier": {
    "singleQuote": true
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}