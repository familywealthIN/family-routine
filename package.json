{
  "name": "routine-notes",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "android:setup": "cd apps/web-app/android && fastlane init",
    "android:release": "turbo run android:release --filter=web-app",
    "android:internal": "turbo run android:internal --filter=web-app"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "googleapis": "^171.4.0",
    "turbo": "^2.4.0"
  },
  "resolutions": {
    "node-libs-browser/readable-stream": "^2.3.8",
    "memory-fs/readable-stream": "^2.3.8",
    "concat-stream/readable-stream": "^2.3.8"
  },
  "overrides": {
    "node-libs-browser": {
      "readable-stream": "^2.3.8"
    },
    "memory-fs": {
      "readable-stream": "^2.3.8"
    },
    "concat-stream": {
      "readable-stream": "^2.3.8"
    }
  },
  "prettier": {
    "singleQuote": true
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "dependencies": {
    "fastlane": "^0.0.9"
  }
}
