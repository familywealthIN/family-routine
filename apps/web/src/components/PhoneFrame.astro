---
interface Props {
  src?: string; // screenshot; omit when passing custom content (e.g. a video) via the slot
  alt?: string;
  width?: number; // viewport width inside the frame
  height?: number; // viewport height inside the frame
  time?: string;  // status bar clock — defaults to Apple's marketing time
}
const { src, alt = '', width = 320, height = 692, time = '9:41' } = Astro.props;
---

<div class="phone-frame" style={`--vw:${width}px;--vh:${height}px;`}>
  <div class="phone-frame__bezel">
    <div class="phone-frame__edge"></div>
    <div class="phone-frame__screen">
      <!-- iOS-style status bar: clock left, signal/wifi/battery right, Dynamic Island centered. -->
      <div class="phone-frame__statusbar" aria-hidden="true">
        <span class="phone-frame__clock">{time}</span>
        <span class="phone-frame__island"></span>
        <span class="phone-frame__indicators">
          <svg viewBox="0 0 18 12" width="18" height="12" aria-hidden="true">
            <rect x="0"  y="7" width="3" height="5" rx="0.6" fill="currentColor"/>
            <rect x="5"  y="5" width="3" height="7" rx="0.6" fill="currentColor"/>
            <rect x="10" y="3" width="3" height="9" rx="0.6" fill="currentColor"/>
            <rect x="15" y="0" width="3" height="12" rx="0.6" fill="currentColor"/>
          </svg>
          <svg viewBox="0 0 18 12" width="18" height="12" aria-hidden="true">
            <path d="M9 11.5a1 1 0 100-2 1 1 0 000 2zM3 7c1.6-1.6 3.7-2.5 6-2.5s4.4.9 6 2.5l-1.4 1.4A6 6 0 009 6.5 6 6 0 004.4 8.4L3 7zm-3-3C2.4 1.6 5.6 0 9 0s6.6 1.6 9 4l-1.4 1.4A10 10 0 009 2 10 10 0 001.4 5.4L0 4z" fill="currentColor"/>
          </svg>
          <span class="phone-frame__battery">
            <span class="phone-frame__battery-cap"></span>
            <span class="phone-frame__battery-fill"></span>
          </span>
        </span>
      </div>

      <div class="phone-frame__content">
        <slot>
          {src && <img src={src} alt={alt} loading="eager" decoding="async" />}
        </slot>
      </div>
    </div>
    <span class="phone-frame__btn phone-frame__btn--silent" aria-hidden="true"></span>
    <span class="phone-frame__btn phone-frame__btn--volup" aria-hidden="true"></span>
    <span class="phone-frame__btn phone-frame__btn--voldn" aria-hidden="true"></span>
    <span class="phone-frame__btn phone-frame__btn--power" aria-hidden="true"></span>
  </div>
</div>

<style>
  .phone-frame {
    --frame-w: calc(var(--vw) + 16px);
    --frame-h: calc(var(--vh) + 16px);
    --bezel-r: 56px;
    --statusbar-h: 50px;
    width: var(--frame-w);
    height: var(--frame-h);
    position: relative;
    filter: drop-shadow(0 50px 60px rgba(13, 27, 42, 0.22))
      drop-shadow(0 16px 24px rgba(13, 27, 42, 0.12));
  }

  .phone-frame__bezel {
    position: absolute;
    inset: 0;
    border-radius: var(--bezel-r);
    background:
      linear-gradient(135deg, #d6dce5 0%, #f5f7fa 18%, #b3becf 50%, #f5f7fa 82%, #d6dce5 100%);
    padding: 8px;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.7),
      inset 0 0 0 2.5px #8696b0,
      inset 0 0 0 3.5px rgba(255, 255, 255, 0.55);
  }

  .phone-frame__edge {
    position: absolute;
    inset: 4px;
    border-radius: calc(var(--bezel-r) - 4px);
    background: #0d1b2a;
  }

  .phone-frame__screen {
    position: absolute;
    inset: 8px;
    border-radius: calc(var(--bezel-r) - 8px);
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
  }

  /* Status bar */
  .phone-frame__statusbar {
    position: relative;
    height: var(--statusbar-h);
    flex-shrink: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 14px 22px 0;
    color: #0d1b2a;
    background: #ffffff;
    z-index: 2;
  }

  .phone-frame__clock {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: -0.01em;
    justify-self: start;
    line-height: 1;
  }

  .phone-frame__island {
    width: 96px;
    height: 28px;
    border-radius: 20px;
    background: #0d1b2a;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    justify-self: center;
  }

  .phone-frame__indicators {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #0d1b2a;
    line-height: 1;
  }

  .phone-frame__battery {
    position: relative;
    display: inline-block;
    width: 24px;
    height: 12px;
    border: 1px solid #0d1b2a;
    border-radius: 3px;
    margin-left: 2px;
  }
  .phone-frame__battery-cap {
    position: absolute;
    top: 3px;
    right: -3px;
    width: 2px;
    height: 4px;
    background: #0d1b2a;
    border-radius: 0 1px 1px 0;
  }
  .phone-frame__battery-fill {
    position: absolute;
    inset: 2px;
    width: 70%;
    background: #0d1b2a;
    border-radius: 1px;
  }

  /* Content area — the actual app screenshot, sized to fill the remaining space. */
  .phone-frame__content {
    flex: 1;
    overflow: hidden;
    position: relative;
  }
  .phone-frame__content img,
  .phone-frame__content :global(video),
  .phone-frame__content :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  /* Side buttons */
  .phone-frame__btn {
    position: absolute;
    background: linear-gradient(180deg, #8696b0 0%, #5b6e8e 50%, #8696b0 100%);
    border-radius: 2px;
  }
  .phone-frame__btn--silent { left: -2px; top: 90px; width: 4px; height: 32px; }
  .phone-frame__btn--volup  { left: -2px; top: 140px; width: 4px; height: 56px; }
  .phone-frame__btn--voldn  { left: -2px; top: 210px; width: 4px; height: 56px; }
  .phone-frame__btn--power  { right: -2px; top: 170px; width: 4px; height: 76px; }

  /* Subtle screen reflection */
  .phone-frame__screen::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(255,255,255,0.18), rgba(255,255,255,0) 35%);
    mix-blend-mode: screen;
    z-index: 3;
  }
</style>
