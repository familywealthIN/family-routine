---
import PhoneFrame from '~/components/PhoneFrame.astro';
import KdgBadge from '~/components/KdgBadge.astro';
import { Icon } from 'astro-icon/components';
import { LINKS } from '~/lib/links';

// Real screenshot will land at /screenshots/home-mobile.png after capture.
// Until then we render a placeholder image with the brand gradient so the
// frame still looks intentional during development.
const heroShot = '/screenshots/home-mobile.png';
---

<section class="relative overflow-hidden pt-12 pb-20 md:pt-20 md:pb-28">
  <!-- subtle background bloom -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute -top-40 -left-32 h-[520px] w-[520px] rounded-full blur-3xl opacity-50"
      style="background:radial-gradient(circle, rgba(40,139,213,0.22), rgba(40,139,213,0) 70%)"></div>
    <div class="absolute -top-24 right-0 h-[480px] w-[480px] rounded-full blur-3xl opacity-60"
      style="background:radial-gradient(circle, rgba(184,217,238,0.5), rgba(184,217,238,0) 70%)"></div>
  </div>

  <div class="container-page grid lg:grid-cols-[1.05fr_1fr] gap-12 lg:gap-16 items-center">
    <!-- Copy -->
    <div data-reveal>
      <span class="pill">
        <Icon name="ph:sparkle-fill" width={14} height={14} />
        The evolution App — built for ambitious people
      </span>

      <h1 class="mt-6 text-[2.6rem] sm:text-6xl lg:text-[4.4rem] font-semibold leading-[1.02]">
        Show up daily. <br />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#288bd5] via-[#5aa3d3] to-[#288bd5]">Evolve weekly.</span>
      </h1>

      <p class="mt-6 text-lg text-[color:var(--color-ink-600)] max-w-xl leading-relaxed">
        Routine Notes turns your daily actions into Kinetics, Discipline, and Geniuses points —
        your personal evolution score. The app is free as long as you keep moving.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={LINKS.appStarted} class="btn-primary text-base">
          Start free — earn your way
          <Icon name="ph:arrow-right" width={16} height={16} />
        </a>
        <a href={LINKS.pricing} class="btn-ghost text-base px-3 py-2">
          See pricing
          <Icon name="ph:caret-right" width={14} height={14} />
        </a>
      </div>

      <ul class="mt-10 flex flex-wrap gap-x-7 gap-y-3 text-sm text-[color:var(--color-ink-500)]">
        <li class="inline-flex items-center gap-2">
          <Icon name="ph:lock-key-fill" width={16} height={16} class="text-[color:var(--color-brand-500)]" />
          Privacy-first by design
        </li>
        <li class="inline-flex items-center gap-2">
          <Icon name="ph:lightning-fill" width={16} height={16} class="text-[color:var(--color-brand-500)]" />
          Earn-your-way pricing
        </li>
        <li class="inline-flex items-center gap-2">
          <Icon name="ph:users-three-fill" width={16} height={16} class="text-[color:var(--color-brand-500)]" />
          Built for accountability
        </li>
      </ul>
    </div>

    <!-- Phone visual -->
    <div class="relative flex justify-center lg:justify-end" data-reveal>
      <div class="relative" style="transform:translateY(0)">
        <PhoneFrame src={heroShot} alt="Routine Notes today view showing Routine points, streak and agents" />
        <div class="hidden sm:block absolute -left-12 top-1/3">
          <KdgBadge />
        </div>
      </div>
    </div>
  </div>
</section>
