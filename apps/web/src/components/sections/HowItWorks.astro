---
import { Icon } from 'astro-icon/components';

const steps = [
  {
    n: '01',
    title: 'Show up daily',
    body: 'Tick your routine agents on time within their 1h 30m punctuality window.',
    icon: 'ph:clock',
  },
  {
    n: '02',
    title: 'Earn Routine points',
    body: 'Up to 100 each for Discipline, Kinetics and Geniuses — 300 points to claim per day.',
    icon: 'ph:lightning',
  },
  {
    n: '03',
    title: 'Spend on AI agents',
    body: 'Run summaries, next-steps and task extraction with the points you actually earned.',
    icon: 'ph:sparkle',
  },
  {
    n: '04',
    title: 'Goals auto-complete',
    body: 'Daily milestones compound into week, month and year wins. You plan once. It cascades.',
    icon: 'ph:tree-structure',
  },
];
---

<section id="how" class="py-24 bg-[color:var(--color-surface-soft)] border-y border-[color:var(--color-ink-100)]">
  <div class="container-page">
    <div class="max-w-2xl mx-auto text-center" data-reveal>
      <span class="pill">
        <Icon name="ph:flow-arrow" width={14} height={14} />
        How it works
      </span>
      <h2 class="mt-5 text-4xl sm:text-5xl font-semibold">
        A four-step loop. <span class="italic font-display text-[color:var(--color-brand-600)]">No fluff.</span>
      </h2>
      <p class="mt-4 text-lg text-[color:var(--color-ink-600)]">
        Built around the unit of work that matters: a single day, done well.
      </p>
    </div>

    <ol data-reveal-group class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-4 relative">
      {/* connecting line */}
      <div class="hidden lg:block absolute top-12 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-[color:var(--color-brand-200)] to-transparent" aria-hidden="true"></div>

      {steps.map((s) => (
        <li data-reveal-item class="card-soft relative p-6 bg-white">
          <div class="flex items-center justify-between">
            <span class="font-display text-[1.5rem] font-semibold text-[color:var(--color-brand-500)] tracking-tight">{s.n}</span>
            <span class="h-10 w-10 rounded-full bg-[color:var(--color-brand-50)] grid place-items-center text-[color:var(--color-brand-600)] ring-1 ring-[color:var(--color-brand-100)]">
              <Icon name={s.icon} width={18} height={18} />
            </span>
          </div>
          <h3 class="mt-5 text-lg font-semibold">{s.title}</h3>
          <p class="mt-2 text-[15px] leading-relaxed text-[color:var(--color-ink-600)]">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
