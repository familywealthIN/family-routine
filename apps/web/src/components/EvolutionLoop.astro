---
/**
 * The amplification diagram: the daily loop (1 show up on time → 2 act with
 * full dedication → 3 improve the plan) deposits points every day; loops
 * compound through the day → week → month → year cascade toward the goal.
 * Pure inline SVG so it inherits brand tokens and ships zero JS.
 */
---

<figure class="evo card-soft not-prose">
  <div class="evo__grid">
    <!-- The daily loop -->
    <svg viewBox="0 0 420 372" role="img" aria-labelledby="evo-loop-title" class="evo__svg">
      <title id="evo-loop-title">
        The daily loop: show up on time, act with full dedication, improve the plan — earning up to 300 points a day.
      </title>
      <defs>
        <marker id="evo-arrow" viewBox="0 0 10 10" refX="7" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0 0 L10 5 L0 10 z" class="evo-arrowhead" />
        </marker>
      </defs>

      <!-- circulating arcs (clockwise), trimmed to leave a clear gap before
           each node circle so arrowheads never slide under the badges -->
      <path d="M252.3 79.8 A118 118 0 0 1 326.6 208.5" class="evo-arc" marker-end="url(#evo-arrow)" />
      <path d="M284.3 281.7 A118 118 0 0 1 135.7 281.7" class="evo-arc" marker-end="url(#evo-arrow)" />
      <path d="M93.4 208.5 A118 118 0 0 1 167.7 79.8" class="evo-arc" marker-end="url(#evo-arrow)" />

      <!-- centre: what one cycle deposits -->
      <text x="210" y="182" text-anchor="middle" class="evo-center-big">+300</text>
      <text x="210" y="204" text-anchor="middle" class="evo-center-small">points / day</text>
      <text x="210" y="224" text-anchor="middle" class="evo-center-tiny">one full loop</text>

      <!-- 1 · Discipline (top) -->
      <g>
        <circle cx="210" cy="72" r="34" class="evo-node" style="stroke:#5aa3d3" />
        <text x="210" y="80" text-anchor="middle" class="evo-letter" style="fill:#5aa3d3">D</text>
        <circle cx="180" cy="46" r="12" class="evo-step" style="fill:#5aa3d3" />
        <text x="180" y="50.5" text-anchor="middle" class="evo-step-num">1</text>
        <text x="210" y="24" text-anchor="middle" class="evo-label">Show up on time</text>
      </g>

      <!-- 2 · Kinetics (lower right) -->
      <g>
        <circle cx="312" cy="249" r="34" class="evo-node" style="stroke:#288bd5" />
        <text x="312" y="257" text-anchor="middle" class="evo-letter" style="fill:#288bd5">K</text>
        <circle cx="345" cy="226" r="12" class="evo-step" style="fill:#288bd5" />
        <text x="345" y="230.5" text-anchor="middle" class="evo-step-num">2</text>
        <text x="312" y="326" text-anchor="middle" class="evo-label">Act with full dedication</text>
      </g>

      <!-- 3 · Geniuses (lower left) -->
      <g>
        <circle cx="108" cy="249" r="34" class="evo-node" style="stroke:#1a5a8f" />
        <text x="108" y="257" text-anchor="middle" class="evo-letter" style="fill:#1a5a8f">G</text>
        <circle cx="75" cy="226" r="12" class="evo-step" style="fill:#1a5a8f" />
        <text x="75" y="230.5" text-anchor="middle" class="evo-step-num">3</text>
        <text x="108" y="326" text-anchor="middle" class="evo-label">Improve the plan</text>
      </g>

      <!-- micro-captions under labels -->
      <text x="210" y="130" text-anchor="middle" class="evo-sublabel">1h 30m punctuality window</text>
      <text x="312" y="344" text-anchor="middle" class="evo-sublabel">sub-tasks, paced every 2h</text>
      <text x="108" y="344" text-anchor="middle" class="evo-sublabel">milestones, re-planned</text>
    </svg>

    <!-- the overnight settlement that feeds the loop back in -->
    <div class="evo__amp" aria-hidden="true">
      <svg viewBox="0 0 64 64" class="evo__amp-arrow">
        <path d="M6 32 H50" class="evo-arc" marker-end="url(#evo-arrow)" />
      </svg>
      <p>Points settle overnight and fund tomorrow’s loop — each cycle starts from a higher baseline.</p>
    </div>

    <!-- The compounding cascade -->
    <svg viewBox="0 0 480 372" role="img" aria-labelledby="evo-curve-title" class="evo__svg">
      <title id="evo-curve-title">
        Loops compound: five day wins auto-complete a week, three weeks a month, nine months a year — bending progress exponentially toward the goal.
      </title>

      <!-- baseline -->
      <line x1="36" y1="330" x2="448" y2="330" class="evo-axis" />

      <!-- effort without a loop: linear, leaks -->
      <path d="M36 326 L448 262" class="evo-flat" />
      <text x="448" y="250" text-anchor="end" class="evo-sublabel">effort without a loop</text>

      <!-- the compounding curve -->
      <path d="M36 326 C 180 318, 290 288, 352 212 S 428 92 444 58" class="evo-curve" />

      <!-- milestones along the curve -->
      <g>
        <circle cx="120" cy="317" r="5" class="evo-dot" />
        <text x="120" y="350" text-anchor="middle" class="evo-label">Day</text>
        <circle cx="220" cy="300" r="5" class="evo-dot" />
        <text x="220" y="350" text-anchor="middle" class="evo-label">Week</text>
        <text x="170" y="286" text-anchor="middle" class="evo-cascade">×5</text>
        <circle cx="320" cy="252" r="5" class="evo-dot" />
        <text x="320" y="350" text-anchor="middle" class="evo-label">Month</text>
        <text x="272" y="252" text-anchor="middle" class="evo-cascade">×3</text>
        <circle cx="408" cy="128" r="5" class="evo-dot" />
        <text x="408" y="350" text-anchor="middle" class="evo-label">Year</text>
        <text x="356" y="168" text-anchor="middle" class="evo-cascade">×9</text>
      </g>

      <!-- the goal -->
      <g>
        <circle cx="444" cy="58" r="16" class="evo-goal" />
        <path d="M444 50 l2.4 4.9 5.4 .8 -3.9 3.8 .9 5.4 -4.8 -2.5 -4.8 2.5 .9 -5.4 -3.9 -3.8 5.4 -.8 z" class="evo-goal-star" />
        <text x="444" y="34" text-anchor="middle" class="evo-label">Goal</text>
      </g>

      <text x="240" y="120" text-anchor="middle" class="evo-curve-label">the loop, compounded</text>
    </svg>
  </div>

  <figcaption class="evo__caption">
    Each loop deposits up to 300 points. Five day wins auto-complete a week, three weeks a month,
    nine months a year — the same daily effort, amplified by the cascade.
  </figcaption>
</figure>

<!-- what the research says each step buys you -->
<div class="evo-research not-prose">
  <div class="evo-research__card">
    <p class="evo-research__step">1 · Show up on time</p>
    <p class="evo-research__fact">
      Time-boxed “if-then” plans raise goal attainment with a medium-to-large effect
      (d ≈ 0.65 across 94 studies — Gollwitzer &amp; Sheeran, 2006). The punctuality window is that plan.
    </p>
  </div>
  <div class="evo-research__card">
    <p class="evo-research__step">2 · Act with full dedication</p>
    <p class="evo-research__fact">
      Repeating the action in a stable context makes it automatic in ~66 days on average
      (Lally et&nbsp;al., 2010). Kinetics points keep the reps honest until the habit carries itself.
    </p>
  </div>
  <div class="evo-research__card">
    <p class="evo-research__step">3 · Improve the plan</p>
    <p class="evo-research__fact">
      1% better every day compounds to ~37× over a year (1.01<sup>365</sup>). Geniuses points reward
      re-planning, so each loop starts slightly smarter than the last.
    </p>
  </div>
</div>

<style>
  .evo {
    padding: 1.75rem 1.5rem;
    margin-top: 2rem;
  }
  .evo__grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .evo__svg {
    flex: 1 1 320px;
    max-width: 460px;
    height: auto;
  }
  .evo__amp {
    flex: 0 1 150px;
    text-align: center;
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--color-ink-500);
  }
  .evo__amp-arrow {
    width: 56px;
    height: 32px;
    margin: 0 auto 0.4rem;
    display: block;
  }
  .evo__caption {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--color-ink-100);
    text-align: center;
    font-size: 13.5px;
    color: var(--color-ink-500);
  }

  /* svg parts */
  .evo-arc {
    fill: none;
    stroke: var(--color-ink-300);
    stroke-width: 2.5;
    stroke-linecap: round;
  }
  .evo-arrowhead {
    fill: var(--color-ink-300);
  }
  .evo-node {
    fill: var(--color-surface);
    stroke-width: 2.5;
    filter: drop-shadow(0 2px 4px rgb(13 27 42 / 0.08));
  }
  .evo-letter {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
  }
  .evo-step {
    stroke: var(--color-surface);
    stroke-width: 2;
  }
  .evo-step-num {
    fill: #fff;
    font-size: 12px;
    font-weight: 700;
  }
  .evo-label {
    fill: var(--color-ink-800);
    font-size: 14.5px;
    font-weight: 600;
  }
  .evo-sublabel {
    fill: var(--color-ink-400);
    font-size: 11.5px;
  }
  .evo-center-big {
    fill: var(--color-brand-600);
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 700;
  }
  .evo-center-small {
    fill: var(--color-ink-600);
    font-size: 13px;
    font-weight: 600;
  }
  .evo-center-tiny {
    fill: var(--color-ink-400);
    font-size: 11px;
  }
  .evo-axis {
    stroke: var(--color-ink-100);
    stroke-width: 2;
  }
  .evo-flat {
    fill: none;
    stroke: var(--color-ink-200);
    stroke-width: 2;
    stroke-dasharray: 5 6;
  }
  .evo-curve {
    fill: none;
    stroke: var(--color-brand-500);
    stroke-width: 3;
    stroke-linecap: round;
  }
  .evo-curve-label {
    fill: var(--color-brand-600);
    font-size: 13px;
    font-weight: 600;
  }
  .evo-dot {
    fill: var(--color-surface);
    stroke: var(--color-brand-500);
    stroke-width: 2.5;
  }
  .evo-cascade {
    fill: var(--color-ink-400);
    font-size: 11.5px;
    font-weight: 600;
  }
  .evo-goal {
    fill: var(--color-brand-500);
    filter: drop-shadow(0 4px 8px rgb(40 139 213 / 0.35));
  }
  .evo-goal-star {
    fill: #fff;
  }

  /* research cards */
  .evo-research {
    margin-top: 1.25rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .evo-research__card {
    background: var(--color-surface-soft);
    border: 1px solid var(--color-ink-100);
    border-radius: var(--radius-card);
    padding: 1rem 1.1rem;
  }
  .evo-research__step {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-600);
  }
  .evo-research__fact {
    margin-top: 0.5rem;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--color-ink-600);
  }
</style>
