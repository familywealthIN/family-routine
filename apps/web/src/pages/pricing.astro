---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import FinalCta from '~/components/sections/FinalCta.astro';
import { LINKS } from '~/lib/links';

const freeIncluded = [
  'All routines, goals, AI agents and KDG tracking',
  'Up to 300 Routine points earnable per day',
  'Check in missed routines with points — agents still run',
  '300 welcome points, +300 per friend you refer',
  'Family / accountability groups',
  'End-to-end encryption',
];

const subIncluded = [
  'Everything in Free, plus:',
  'Unlimited missed-task redemptions (no point cost)',
  'Agents fire on redeemed tasks — never lose a day',
  'Priority support',
  'Early access to new features',
];
---

<BaseLayout title="Pricing — Routine Notes" description="Free if you show up. Subscribe only when you don't. $4.99/month or $49.99/year — redeem any missed task, any day.">
  <!-- intro -->
  <section class="relative pt-20 pb-16 overflow-hidden">
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 h-[420px] w-[640px] rounded-full blur-3xl opacity-50"
        style="background:radial-gradient(circle, rgba(40,139,213,0.18), rgba(40,139,213,0) 70%)"></div>
    </div>
    <div class="container-page text-center max-w-3xl mx-auto" data-reveal>
      <span class="pill">
        <Icon name="ph:coins" width={14} height={14} />
        Earn-your-way pricing
      </span>
      <h1 class="mt-6 text-5xl sm:text-6xl lg:text-7xl font-semibold leading-[1.02]">
        Free if you <span class="italic font-display text-[color:var(--color-brand-600)]">show up.</span>
      </h1>
      <p class="mt-6 text-lg text-[color:var(--color-ink-600)]">
        No trial. No card on file. Earn up to 300 Routine points a day by executing your routines —
        and when life gets in the way, spend them to redeem the tasks you missed. Subscribe only
        when you stop earning.
      </p>
    </div>
  </section>

  <!-- mechanic panel -->
  <section class="container-page">
    <div class="card-soft p-8 sm:p-10 grid lg:grid-cols-[1.2fr_1fr] gap-10 items-center" data-reveal>
      <div>
        <h2 class="text-3xl sm:text-4xl font-semibold">How earn-your-way works</h2>
        <ul class="mt-6 space-y-4 text-[15px] text-[color:var(--color-ink-700)]">
          <li class="flex gap-3">
            <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-brand-50)] text-[color:var(--color-brand-600)] ring-1 ring-[color:var(--color-brand-100)] font-display font-semibold text-sm">1</span>
            <p><b>Tick routines on time</b> — each on-time check inside the 1h 30m window earns Discipline.</p>
          </li>
          <li class="flex gap-3">
            <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-brand-50)] text-[color:var(--color-brand-600)] ring-1 ring-[color:var(--color-brand-100)] font-display font-semibold text-sm">2</span>
            <p><b>Knock out sub-tasks</b> paced every 2 hours during a routine slot → Kinetics.</p>
          </li>
          <li class="flex gap-3">
            <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-brand-50)] text-[color:var(--color-brand-600)] ring-1 ring-[color:var(--color-brand-100)] font-display font-semibold text-sm">3</span>
            <p><b>Link to milestones</b> for week → month → year goals → Geniuses, compounding.</p>
          </li>
          <li class="flex gap-3">
            <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-brand-50)] text-[color:var(--color-brand-600)] ring-1 ring-[color:var(--color-brand-100)] font-display font-semibold text-sm">4</span>
            <p><b>Missed checking a routine on time?</b> Spend yesterday's points to check it in anyway — keep the streak, and its agents still run.</p>
          </li>
        </ul>
      </div>
      <div class="rounded-2xl bg-[color:var(--color-surface-soft)] border border-[color:var(--color-ink-100)] p-6">
        <p class="text-xs uppercase tracking-[0.14em] font-semibold text-[color:var(--color-ink-500)]">Daily budget</p>
        <p class="mt-3 font-display text-6xl font-semibold leading-none">300<span class="text-2xl text-[color:var(--color-ink-400)]">/day</span></p>
        <ul class="mt-5 space-y-2 text-sm text-[color:var(--color-ink-700)]">
          <li class="flex justify-between"><span><b class="text-[color:var(--color-brand-600)] font-display">D</b> Discipline — show up on time</span><b>100</b></li>
          <li class="flex justify-between"><span><b class="text-[color:var(--color-brand-500)] font-display">K</b> Kinetics — do the work</span><b>100</b></li>
          <li class="flex justify-between"><span><b class="text-[color:var(--color-brand-800)] font-display">G</b> Geniuses — plan & cascade</span><b>100</b></li>
        </ul>
        <p class="mt-4 text-xs text-[color:var(--color-ink-500)]">Points settle overnight — today's earnings rescue tomorrow's misses. Subscribe only when your earning isn't covering your misses.</p>
      </div>
    </div>
  </section>

  <!-- two tiers -->
  <section class="container-page mt-20">
    <div data-reveal-group class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <article data-reveal-item class="card-soft p-8 flex flex-col">
        <span class="pill self-start">
          <Icon name="ph:gift" width={14} height={14} />
          Free
        </span>
        <h3 class="mt-5 text-2xl font-semibold">Earn-your-way</h3>
        <p class="mt-2 text-[color:var(--color-ink-500)] text-sm">For anyone willing to show up.</p>
        <p class="mt-6 font-display text-6xl font-semibold leading-none">$0<span class="text-2xl text-[color:var(--color-ink-400)]"> /forever</span></p>
        <ul class="mt-7 space-y-3 text-[14.5px]">
          {freeIncluded.map((it) => (
            <li class="flex gap-2.5">
              <Icon name="ph:check-circle-fill" width={18} height={18} class="text-[color:var(--color-brand-500)] mt-0.5 shrink-0" />
              <span class="text-[color:var(--color-ink-700)]">{it}</span>
            </li>
          ))}
        </ul>
        <a href={LINKS.appStarted} class="mt-8 inline-flex items-center justify-center gap-2 rounded-2xl border border-[color:var(--color-ink-200)] px-5 py-3 font-semibold text-[color:var(--color-ink-900)] hover:border-[color:var(--color-brand-400)] hover:text-[color:var(--color-brand-600)] transition-colors">
          Start free
          <Icon name="ph:arrow-right" width={16} height={16} />
        </a>
      </article>

      <article data-reveal-item class="relative rounded-[20px] bg-[color:var(--color-ink-900)] text-white p-8 flex flex-col overflow-hidden">
        <div class="absolute -top-32 -right-24 h-72 w-72 rounded-full blur-3xl opacity-30" style="background:radial-gradient(circle,#5aa3d3,transparent 70%)"></div>
        <span class="relative inline-flex self-start items-center gap-2 rounded-full bg-white/10 border border-white/20 px-3 py-1.5 text-[13px] font-medium">
          <Icon name="ph:sparkle-fill" width={14} height={14} />
          Subscriber
        </span>
        <h3 class="relative mt-5 text-2xl font-semibold">Never lose a day</h3>
        <p class="relative mt-2 text-white/60 text-sm">When earning isn’t keeping up.</p>
        <p class="relative mt-6 font-display text-6xl font-semibold leading-none">$4.99<span class="text-2xl text-white/60"> /month</span></p>
        <p class="relative mt-1 text-sm text-white/60">or $49.99 / year — 2 months free</p>
        <ul class="relative mt-7 space-y-3 text-[14.5px]">
          {subIncluded.map((it, i) => (
            <li class="flex gap-2.5">
              <Icon name="ph:check-circle-fill" width={18} height={18} class={`mt-0.5 shrink-0 ${i === 0 ? 'text-white/40' : 'text-[color:var(--color-brand-300)]'}`} />
              <span class={i === 0 ? 'text-white/60 italic' : 'text-white/90'}>{it}</span>
            </li>
          ))}
        </ul>
        <a href={LINKS.appStarted} class="relative mt-8 inline-flex items-center justify-center gap-2 rounded-2xl bg-white text-[color:var(--color-ink-900)] px-5 py-3 font-semibold hover:bg-[color:var(--color-brand-50)] transition-colors">
          Subscribe — $4.99/mo
          <Icon name="ph:arrow-right" width={16} height={16} />
        </a>
      </article>
    </div>

    <p class="mt-8 text-center text-sm text-[color:var(--color-ink-500)]">
      All other features — routines, goals, KDG, sharing, encryption — are free for everyone, forever.
    </p>
  </section>

  <div class="mt-24">
    <FinalCta />
  </div>
</BaseLayout>
